<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>IB11 Chemistry SL M26 Online Exam</title>

<style>
@page { size: A4; margin: 14mm; }
* { box-sizing: border-box; }

body {
  font-family: Arial, sans-serif;
  background: #d9d9d9;
  margin: 0;
  color: #111;
  user-select: none;
}

.exam-page {
  width: 210mm;
  min-height: 297mm;
  margin: 20px auto;
  background: white;
  padding: 18mm;
  box-shadow: 0 0 12px rgba(0,0,0,0.25);
}

.header {
  text-align: center;
  border-bottom: 2px solid #000;
  padding-bottom: 12px;
}

.header h1 { font-size: 17px; margin: 0; text-transform: uppercase; }
.header h2 { font-size: 15px; margin: 6px 0; }

.meta {
  margin-top: 16px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px 24px;
  font-size: 14px;
}

.student-box {
  margin: 18px 0;
  padding: 12px;
  border: 1px solid #000;
}

.student-box input {
  width: 100%;
  padding: 8px;
  margin: 6px 0 12px;
  border: 1px solid #555;
  font-size: 14px;
}

.notice {
  background: #f6f6f6;
  border-left: 5px solid #111;
  padding: 10px;
  font-size: 13px;
  margin: 15px 0;
}

.timer {
  display: none;
  position: sticky;
  top: 0;
  background: #111;
  color: white;
  padding: 12px;
  text-align: center;
  font-weight: bold;
  z-index: 999;
}

.prestart-message {
  border: 2px solid #000;
  padding: 14px;
  margin: 18px 0;
  background: #f8f8f8;
  font-size: 14px;
}

#examContent {
  display: none;
}

.question {
  border: 1px solid #999;
  padding: 14px;
  margin: 18px 0;
  page-break-inside: avoid;
}

.question h3 {
  margin-top: 0;
  font-size: 16px;
}

.question label {
  display: block;
  margin: 8px 0;
  line-height: 1.5;
}

.answer-area {
  min-height: 150px;
  border: 1px solid #666;
  padding: 10px;
  margin-top: 8px;
  background: #fff;
  user-select: text;
  font-size: 14px;
}

.toolbar {
  margin: 8px 0;
  padding: 6px;
  border: 1px solid #aaa;
  background: #f3f3f3;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.toolbar button {
  padding: 5px 10px;
  font-size: 13px;
  cursor: pointer;
}

table {
  width: 100%;
  border-collapse: collapse;
  margin: 12px 0;
}

td, th {
  border: 1px solid #000;
  padding: 7px;
  text-align: left;
}

.btns {
  text-align: center;
  margin: 25px 0;
}

button.main {
  background: #111;
  color: white;
  border: none;
  padding: 12px 20px;
  margin: 6px;
  font-size: 14px;
  cursor: pointer;
}

button.main:hover {
  background: #444;
}

#printBtn { display: none; }

.finished-box {
  display: none;
  border: 2px solid #000;
  padding: 15px;
  margin-top: 20px;
  background: #f8f8f8;
}

.warning {
  color: #b00000;
  font-weight: bold;
}

@media print {
  body { background: white; }
  .exam-page {
    box-shadow: none;
    margin: 0;
    width: auto;
    padding: 10mm;
  }
  .timer, .toolbar, .btns, #startBtn, #fullscreenBtn, #prestartMessage {
    display: none !important;
  }
  #examContent {
    display: block !important;
  }
}
</style>
</head>

<body oncontextmenu="return false">

<div class="timer" id="timerBar">
  Time Remaining: <span id="timer">65:00</span> |
  Anti-cheat warnings: <span id="warnings">0</span>
</div>

<div class="exam-page">

  <div class="header">
    <h1>THE WESTERN AUSTRALIAN INTERNATIONAL SCHOOL SYSTEM</h1>
    <h2>PAPER EXAM FOR END OF SEMESTER 2</h2>
    <p><strong>SCHOOL YEAR: 2025–2026</strong></p>
  </div>

  <div class="meta">
    <div><strong>Year:</strong> IB–11</div>
    <div><strong>Duration:</strong> 65 minutes</div>
    <div><strong>Subject:</strong> CHEMISTRY IBDP</div>
    <div><strong>Version:</strong> SL</div>
    <div><strong>Code:</strong> M26</div>
    <div><strong>Total:</strong> 40 marks</div>
  </div>

  <div class="student-box">
    <label><strong>Student Name</strong></label>
    <input type="text" id="studentName" placeholder="Type your full name">

