  </div>

  <div class="finished-box" id="finishedBox">
    <h2>Exam Finished</h2>
    <p><strong>Your response is now locked.</strong></p>
    <p><strong>Finished Date and Time:</strong> <span id="finishDateTime"></span></p>
    <p><strong>Number of Anti-cheat Warnings:</strong> <span id="finalWarnings"></span></p>
    <p>You may now click <strong>Print / Save PDF Response</strong>.</p>
    <p class="warning">No score or answer key is shown. Responses must be checked by the teacher.</p>
  </div>

</div>

<script>
let timeLeft = 65 * 60;
let timerInterval;
let finished = false;
let warningCount = 0;
let examStarted = false;

const deadline = new Date("2026-12-31T23:59:00").getTime();

class EditorToolbar extends HTMLElement {
  connectedCallback() {
    this.innerHTML = `
      <div class="toolbar">
        <button type="button" onclick="cmd('bold')"><b>B</b></button>
        <button type="button" onclick="cmd('italic')"><i>I</i></button>
        <button type="button" onclick="cmd('underline')"><u>U</u></button>
        <button type="button" onclick="cmd('superscript')">x²</button>
        <button type="button" onclick="cmd('subscript')">x₂</button>
        <button type="button" onclick="insertSymbol('°')">°</button>
        <button type="button" onclick="insertSymbol('→')">→</button>
        <button type="button" onclick="insertSymbol('⇌')">⇌</button>
      </div>
    `;
  }
}
customElements.define("editor-toolbar", EditorToolbar);

function cmd(command) {
  document.execCommand(command, false, null);
}

function insertSymbol(symbol) {
  document.execCommand("insertText", false, symbol);
}

function enterFullscreen() {
  if (document.documentElement.requestFullscreen) {
    document.documentElement.requestFullscreen().catch(() => {
      alert("Fullscreen failed. Please allow fullscreen mode in your browser.");
    });
  } else {
    alert("Fullscreen is not supported in this browser.");
  }
}

function startExam() {
  const name = document.getElementById("studentName").value.trim();
  const email = document.getElementById("studentEmail").value.trim();

  if (!name || !email) {
    alert("Please enter student name and email before starting.");
    return;
  }

  if (new Date().getTime() > deadline) {
    document.body.innerHTML =
      "<h1 style='text-align:center;margin-top:100px;'>Exam Closed</h1>";
    return;
  }

  if (!document.fullscreenElement) {
    alert("You must click Enter Fullscreen first before starting the exam.");
    return;
  }

  examStarted = true;

  document.getElementById("examContent").style.display = "block";
  document.getElementById("prestartMessage").style.display = "none";
  document.getElementById("timerBar").style.display = "block";

  timerInterval = setInterval(updateTimer, 1000);

  document.getElementById("startBtn").disabled = true;
  document.getElementById("fullscreenBtn").disabled = true;
  document.getElementById("studentName").readOnly = true;
  document.getElementById("studentEmail").readOnly = true;
}

function updateTimer() {
  timeLeft--;

  let minutes = Math.floor(timeLeft / 60);
  let seconds = timeLeft % 60;

  document.getElementById("timer").textContent =
    String(minutes).padStart(2,"0") + ":" + String(seconds).padStart(2,"0");

  if (timeLeft <= 0) {
    clearInterval(timerInterval);
    finishExam();
    alert("Time is finished. Your exam has been automatically finished.");
  }

  if (new Date().getTime() > deadline) {
    finishExam();
    document.body.innerHTML =
      "<h1 style='text-align:center;margin-top:100px;'>Exam Closed After Deadline</h1>";
  }
}

function finishExam() {
  if (finished) return;
  finished = true;

  document.querySelectorAll("input").forEach(el => {
    el.disabled = true;
  });

  document.querySelectorAll(".answer-area").forEach(el => {
    el.contentEditable = false;
  });

  document.querySelectorAll(".toolbar").forEach(el => {
    el.style.display = "none";
  });

  document.getElementById("printBtn").style.display = "inline-block";
  document.getElementById("finishedBox").style.display = "block";

  const finishedTime = new Date();
  document.getElementById("finishDateTime").textContent =
    finishedTime.toLocaleString();

  document.getElementById("finalWarnings").textContent = warningCount;

  clearInterval(timerInterval);
}

document.addEventListener("copy", function(e) {
  e.preventDefault();
  if (examStarted && !finished) addWarning();
});

document.addEventListener("cut", function(e) {
  e.preventDefault();
  if (examStarted && !finished) addWarning();
});

document.addEventListener("paste", function(e) {
  e.preventDefault();
  if (examStarted && !finished) addWarning();
});

document.addEventListener("keydown", function(e) {
  if (e.ctrlKey || e.key === "F12" || e.key === "PrintScreen") {
    e.preventDefault();
    if (examStarted && !finished) addWarning();
  }
});

document.addEventListener("visibilitychange", function() {
  if (document.hidden && examStarted && !finished) addWarning();
});

document.addEventListener("fullscreenchange", function() {
  if (!document.fullscreenElement && examStarted && !finished) {
    addWarning();
    alert("Warning: You exited fullscreen mode.");
  }
});

function addWarning() {
  warningCount++;
  document.getElementById("warnings").textContent = warningCount;
}
</script>

</body>
</html>
